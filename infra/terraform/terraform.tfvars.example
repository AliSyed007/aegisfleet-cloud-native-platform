aws_region        = "eu-central-1"
project_name      = "aegisfleet"
environment       = "dev"
instance_type     = "t3.medium"
availability_zone = "eu-central-1a"

vpc_cidr_block           = "10.20.0.0/16"
public_subnet_cidr_block = "10.20.1.0/24"

# Replace with your real SSH public key content before terraform plan/apply.
ssh_public_key = "ssh-ed25519 AAAA_REPLACE_ME your_email@example.com"

# Recommended: replace 0.0.0.0/0 with your public IP /32 before apply.
# Example: ["203.0.113.10/32"]
allowed_admin_cidr_blocks = ["0.0.0.0/0"]

# For portfolio demo, API can be restricted to your IP too.
allowed_api_cidr_blocks = ["0.0.0.0/0"]
