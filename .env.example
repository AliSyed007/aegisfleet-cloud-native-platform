# -------------------------
# AegisFleet Environment Example
# -------------------------
# Copy this file to .env for local development:
# cp .env.example .env
#
# Never commit real .env files to GitHub.

# Simulator
VEHICLE_COUNT=50
API_URL=http://api:8000/telemetry
SEND_INTERVAL_SECONDS=2
LOG_LEVEL=INFO

# FastAPI
API_HOST=0.0.0.0
API_PORT=8000

# PostgreSQL
POSTGRES_DB=aegisfleet
POSTGRES_USER=aegisfleet_user
POSTGRES_PASSWORD=change_me_locally
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Grafana
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change_me_locally

# Prometheus
PROMETHEUS_SCRAPE_INTERVAL=5s
